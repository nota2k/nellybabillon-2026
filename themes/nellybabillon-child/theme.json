{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "spacing": {
            "padding": true,
            "margin": true,
            "units": [ "px", "em", "rem", "vh", "vw", "%" ]
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1280px"
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "Niramit",
                    "name": "Niramit",
                    "slug": "niramit",
                    "fontFace": [
                        {
                            "fontFamily": "Niramit",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontStretch": "normal",
                            "src": [ "file:./assets/fonts/Niramit/Niramit-Regular.ttf" ]
                        }
                    ]
                },
                {
                    "fontFamily": "Arnold Boecklin",
                    "name": "Arnold Boecklin",
                    "slug": "arnold-boecklin",
                    "fontFace": [
                        {
                            "fontFamily": "Arnold Boecklin",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontStretch": "normal",
                            "src": [ "file:./assets/fonts/ArnoldBoecklinLT.ttf" ]
                        }
                    ]
                }
            ]
        }
    }
}
